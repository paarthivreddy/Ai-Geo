# Backend Configuration
# GeoCare AI – India Patient Address Intelligence Platform

# Database
DATABASE_URL=postgresql+asyncpg://postgres:GeocareDB%402026@127.0.0.1:7117/geocare
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# OSM PostGIS (separate instance)
OSM_DATABASE_URL=postgresql+asyncpg://postgres:GeocareDB@2026@localhost:5433/osm

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CLUSTER_URLS=redis://localhost:6379/0,redis://localhost:6380/0,redis://localhost:6381/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_CONCURRENCY=4
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true

# Geography Data
GEOGRAPHY_DATA_PATH=/data/geography
LIBPOSTAL_DATA_DIR=/usr/local/share/libpostal

# File Upload
MAX_FILE_SIZE_MB=2048
UPLOAD_DIR=/data/uploads
CHUNK_DIR=/data/chunks
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls

# Processing
DEFAULT_CHUNK_SIZE=50000
MAX_CHUNK_SIZE=200000
MIN_CHUNK_SIZE=5000
FUZZY_THRESHOLD=85

# Auth
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9090
